{
  "manifest_version": 3,
  "name": "Google Maps Scraper",
  "version": "1.0.0",
  "description": "Googleマップから店舗情報を抽出してCSVでダウンロードする拡張機能",
  "permissions": [
    "activeTab",
    "scripting",
    "storage",
    "notifications",
    "downloads",
    "power",
    "alarms"
  ],
  "host_permissions": [
    "https://www.google.com/maps/*",
    "https://www.google.co.jp/maps/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "https://www.google.com/maps/search/*",
        "https://www.google.co.jp/maps/search/*"
      ],
      "js": ["content.js"]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
